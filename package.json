{
  "name": "roadie",
  "displayName": "Roadie MCP Server",
  "description": "Roadie: The Plug and Forget autonomous AI project engine (Standalone MCP Server).",
  "version": "0.12.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "copilot",
    "ai",
    "workflow",
    "automation",
    "code review"
  ],
  "main": "./out/index.js",
  "scripts": {
    "build": "tsup src/index.ts --outDir out --clean",
    "build:watch": "npm run build -- --watch",
    "lint": "eslint src --ext ts",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write src",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "start": "node out/index.js"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2",
    "@mendable/firecrawl-js": "^4.18.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^9.4.3",
    "dotenv": "^17.4.2",
    "fast-glob": "^3.3.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^8.50.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.2.0",
    "vitest": "^0.34.0"
  },
  "bundleDependencies": [
    "better-sqlite3"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rmg007/Roadie_App.git"
  },
  "license": "MIT",
  "homepage": "https://github.com/rmg007/Roadie_App",
  "bugs": {
    "url": "https://github.com/rmg007/Roadie_App/issues"
  },
  "bin": {
    "roadie-mcp": "./out/index.js",
    "roadie": "./out/index.js"
  }
}
